; --- Map3DOverlay: 2D 端末ペインに重ねる 3D オーバーレイ ---
; - SubViewportContainer が pane 内の指定 Rect を埋めて 3D シーンを表示する。
; - SubViewport 内に Camera3D / DirectionalLight3D / GodotMap3D を配置する。

[node name="Map3DOverlay" type="SubViewportContainer"]
script = ExtResource("1_overlay")
stretch = true
mouse_filter = 2
custom_minimum_size = Vector2(0, 0)

[node name="SubViewport" type="SubViewport" parent="."]
own_world_3d = true
world_3d = SubResource("World3D_dungeon")
transparent_bg = false
handle_input_locally = false
render_target_update_mode = 3
size = Vector2i(640, 400)

[node name="Camera3D" type="Camera3D" parent="SubViewport"]
transform = Transform3D(1, 0, 0, 0, 0.5, 0.866, 0, -0.866, 0.5, 0, 18, 18)
fov = 55.0
near = 0.1
far = 200.0

[node name="DirectionalLight3D" type="DirectionalLight3D" parent="SubViewport"]
transform = Transform3D(0.7071, -0.5, 0.5, 0, 0.7071, 0.7071, -0.7071, -0.5, 0.5, 0, 20, 0)
