size_flags_horizontal = 0
text = "サイズ"

[node name="FontSizeSpinBox" type="SpinBox" parent="ConfigLayer/ConfigPanel/PanelVBox/FontSizeRow"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 8.0
max_value = 48.0
step = 1.0
value = 16.0

[node name="TileRow" type="HBoxContainer" parent="ConfigLayer/ConfigPanel/PanelVBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TileLabel" type="Label" parent="ConfigLayer/ConfigPanel/PanelVBox/TileRow"]
