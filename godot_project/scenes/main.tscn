[node name="TileOption" type="OptionButton" parent="ConfigLayer/ConfigPanel/PanelVBox/TileRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="BigtileRow" type="HBoxContainer" parent="ConfigLayer/ConfigPanel/PanelVBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="BigtileLabel" type="Label" parent="ConfigLayer/ConfigPanel/PanelVBox/BigtileRow"]
