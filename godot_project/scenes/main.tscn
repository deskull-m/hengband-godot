[node name="ButtonRow" type="HBoxContainer" parent="ConfigLayer/ConfigPanel/PanelVBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ApplyButton" type="Button" parent="ConfigLayer/ConfigPanel/PanelVBox/ButtonRow"]
