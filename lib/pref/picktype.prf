?:1

#---------------------------------------------------------------------
# 職業別処理
#---------------------------------------------------------------------

# 狂戦士は使用できない巻物、杖、魔法棒、ロッドを全て破壊する。
?:[EQU $CLASS Berserker]
!魔法アイテム
?:1

?:[EQU $CLASS Archer]
# アーチャー
の骨
頭蓋骨の破片
骨の破片
折れた棒

?:[EQU $CLASS Ninja]
# 忍者
~エゴ防具:闇の
収集中のくさび#@v0=g
~くさび

# Tabキーにくさびを投げるマクロを登録
A:\e\e\ev0*t
P:\t

?:[AND [LEQ $LEVEL 10] [NOT [EQU $CLASS Ninja]]]
# 忍者以外はだいたい最序盤松明を投げる
(!未鑑定の松明
松明#@v0=g

# Tabキーに松明を投げるマクロを登録
A:\e\e\ev0*t
P:\t

?:[AND [GEQ $LEVEL 11] [NOT [EQU $CLASS Ninja]]]
# それ以降は射撃マクロを登録
# Roguelikeキー配置の場合
#A:\e\e\et0*t
#P:\t
# オリジナルキー配置の場合
A:\e\e\ef0*t
P:\t

# または魔法用マクロを登録
# A:\e\e\emaa*t
# P:\t
?:1

