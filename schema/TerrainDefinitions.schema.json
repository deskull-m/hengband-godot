                  "TRAPDOOR",
                  "PIT",
                  "SPIKED_PIT",
                  "POISON_PIT",
                  "TY_CURSE",
                  "TELEPORT",
                  "FIRE",
                  "ACID",
                  "SLOW",
                  "LOSE_STR",
