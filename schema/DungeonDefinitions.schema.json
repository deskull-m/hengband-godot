{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "DungeonDefinitions.schema.jsonc",
  "title": "DungeonDefinitions",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "dungeons"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "dungeons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dungeon"
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ja", "en"],
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minDepth", "maxDepth", "minPlayerLevel", "objGood", "objGreat", "pit", "nest"],
      "properties": {
        "minDepth": {
          "type": "integer",
          "minimum": 0
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 0
        },
        "minPlayerLevel": {
          "type": "integer",
          "minimum": 0
        },
        "objGood": {
          "type": "integer",
          "minimum": 0
        },
        "objGreat": {
          "type": "integer",
          "minimum": 0
        },
        "pit": {
          "$ref": "#/$defs/hex16String"
        },
        "nest": {
          "$ref": "#/$defs/hex16String"
        }
      }
    },
    "monsters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minAlloc", "maxAllocChance", "normalMonsterRate", "flagsMode"],
      "properties": {
        "minAlloc": {
          "type": "integer",
          "minimum": 0
        },
        "maxAllocChance": {
          "type": "integer",
          "minimum": 0
        },
        "normalMonsterRate": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "flagsMode": {
          "type": "integer",
          "enum": [0, 1, 2, 3, 4]
        },
        "flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterFlag"
          }
        },
        "spells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/monsterSpell"
          }
        }
      }
    },
    "floor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tiles", "tunnelRate"],
      "properties": {
        "tiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/floorTile"
          }
        },
        "tunnelRate": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "wall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tiles", "outer", "inner", "stream1", "stream2"],
      "properties": {
        "tiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/wallTile"
          }
        },
        "outer": {
          "$ref": "#/$defs/wallTerrain"
        },
        "inner": {
          "$ref": "#/$defs/wallTerrain"
        },
        "stream1": {
          "$ref": "#/$defs/wallTerrain"
        },
        "stream2": {
          "$ref": "#/$defs/wallTerrain"
        }
      }
    },
    "floorTile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "rate"],
      "properties": {
        "type": {
          "enum": [
            "DEEP_LAVA",
            "DEEP_WATER",
            "DIRT",
            "FLOOR",
            "FLOWER",
            "GLASS_FLOOR",
            "GRASS",
            "SHALLOW_LAVA",
            "SHALLOW_WATER"
          ]
        },
        "rate": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "wallTile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "rate"],
      "properties": {
        "type": {
          "enum": [
            "DARK_PIT",
            "DEEP_LAVA",
            "DEEP_WATER",
            "GLASS_WALL",
            "GRANITE",
            "MAGMA_TREASURE",
            "MOUNTAIN_WALL",
            "PERMANENT",
            "QUARTZ_TREASURE",
            "SHALLOW_WATER",
            "TREE"
          ]
        },
        "rate": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "wallTerrain": {
      "type": "string",
      "enum": [
        "BRAKE",
        "DARK_PIT",
        "DEEP_LAVA",
        "DEEP_WATER",
        "GLASS_WALL",
        "GRANITE",
        "MAGMA_VEIN",
        "MOUNTAIN_WALL",
        "NONE",
        "PERMANENT",
        "QUARTZ_VEIN",
        "SHALLOW_WATER",
        "TREE"
      ]
    },
    "hex16String": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{4}$"
    },
    "dungeonFlag": {
      "type": "string",
      "enum": [
        "ACID_RIVER",
        "ARCADE",
        "ARENA",
        "BEGINNER",
        "CAVE",
        "CAVERN",
        "CHAMELEON",
        "CURTAIN",
        "DARKNESS",
        "DESTROY",
        "FINAL_ARTIFACT_107",
        "FINAL_ARTIFACT_129",
        "FINAL_ARTIFACT_89",
        "FINAL_GUARDIAN_1034",
        "FINAL_GUARDIAN_1041",
        "FINAL_GUARDIAN_237",
        "FINAL_GUARDIAN_373",
        "FINAL_GUARDIAN_468",
        "FINAL_GUARDIAN_481",
        "FINAL_GUARDIAN_803",
        "FINAL_GUARDIAN_804",
        "FINAL_GUARDIAN_854",
        "FINAL_GUARDIAN_857",
        "FINAL_GUARDIAN_882",
        "FINAL_GUARDIAN_972",
        "FINAL_OBJECT_148",
        "FINAL_OBJECT_239",
        "FINAL_OBJECT_354",
        "FINAL_OBJECT_426",
        "FINAL_OBJECT_592",
        "FINAL_OBJECT_617",
        "FINAL_OBJECT_629",
        "FORGET",
        "GLASS_DOOR",
        "GLASS_ROOM",
        "LAKE_ACID",
        "LAKE_LAVA",
        "LAKE_POISONOUS",
        "LAKE_RUBBLE",
        "LAKE_TREE",
        "LAKE_WATER",
        "LARGE",
        "LARGEST",
        "LAVA_RIVER",
        "MAZE",
        "NO_CAVE",
        "NO_DOORS",
        "NO_MAGIC",
        "NO_MELEE",
        "NO_VAULT",
        "POISONOUS_RIVER",
        "SMALL",
        "SMALLEST",
        "WATER_RIVER",
        "WINNER"
      ]
    },
    "monsterFlag": {
      "type": "string",
      "enum": [
        "ANIMAL",
        "AQUATIC",
        "CAN_FLY",
        "CAN_SWIM",
        "CHAMELEON",
        "DEMON",
        "DRAGON",
        "ELDRITCH_HORROR",
        "EVIL",
        "GIANT",
        "GOOD",
        "HAS_DARK_1",
        "HAS_DARK_2",
        "HAS_LITE_1",
        "HAS_LITE_2",
        "IM_FIRE",
        "INVISIBLE",
        "NONLIVING",
        "ORC",
        "R_CHAR_$",
        "R_CHAR_OYH",
        "R_CHAR_SJZ#",
        "R_CHAR_dD",
        "R_CHAR_oOT",
        "R_CHAR_phHg",
        "R_CHAR_y",
        "SELF_DARK_1",
        "SELF_DARK_2",
        "SELF_LITE_1",
        "SELF_LITE_2",
        "TROLL",
        "UNDEAD",
        "WILD_MOUNTAIN",
        "WILD_OCEAN",
        "WILD_VOLCANO",
        "WILD_WOOD"
      ]
    },
    "monsterSpell": {
      "type": "string",
      "enum": ["BA_DARK", "BA_LITE", "BR_DARK", "BR_LITE"]
    },
    "dungeon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "position",
        "generation",
        "monsters",
        "floor",
        "wall",
        "flags"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "position": {
          "$ref": "#/$defs/position"
        },
        "generation": {
          "$ref": "#/$defs/generation"
        },
        "monsters": {
          "$ref": "#/$defs/monsters"
        },
        "floor": {
          "$ref": "#/$defs/floor"
        },
        "wall": {
          "$ref": "#/$defs/wall"
        },
        "flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dungeonFlag"
          }
        }
      }
    }
  }
}
